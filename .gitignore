node_modules/
.env
.env.*
!.env.example
config/google-service-account.json
data/canva-tokens.json
data/canva-pkce.json
data/*.db
data/*.db-shm
data/*.db-wal
data/*.db-journal

# Local SQLite backups (snapshots live on disk + off-site Drive, never in git)
backups/

logs/
*.log
.DS_Store

# Brand assets — heavy avatars (svg/png/json tracked, jpg excluded)
config/brand/*.jpg

# Runtime lock files (PID-based single-instance guard)
*.lock
data/*.lock

# Font debug / test scripts and their output PDFs
font-test-*.js
font-test-*.pdf

# Generated PDF/PPTX exports — keep the directory via .gitkeep
exports/*.pdf
exports/*.pptx
!exports/.gitkeep
data/recent-photos.json
data/content-plan.json
