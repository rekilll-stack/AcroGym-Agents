# ─────────────────────────────────────────
# Admin bot — operational alerts
# (карточки лидов, напоминания) → admins
# ─────────────────────────────────────────
ADMIN_BOT_TOKEN=
ADMIN_CHAT_IDS=216299177

# ─────────────────────────────────────────
# Owner bot — strategic/analytical updates
# (morning digest, business metrics) → owners only
# ─────────────────────────────────────────
OWNER_BOT_TOKEN=
OWNER_CHAT_IDS=216299177

# ─────────────────────────────────────────
# CONTENT_BOT (Agent 4) — separate bot for Instagram content drafts
# Access restricted to CONTENT_CHAT_IDS (defaults to Kirill if unset).
# ─────────────────────────────────────────
CONTENT_BOT_TOKEN=
CONTENT_CHAT_IDS=216299177

# ─────────────────────────────────────────
# Claude API (получить на console.anthropic.com)
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────
# Google Sheets
# ─────────────────────────────────────────
GOOGLE_SHEET_ID=1SL94orhjzIsUa86-Uln-GC-B5v0AtiuAF-UQ1uL6Zgs
GOOGLE_SHEET_RESPONSES_TAB=Form Responses 1
GOOGLE_SERVICE_ACCOUNT_PATH=./config/google-service-account.json

# ─────────────────────────────────────────
# Settings
# ─────────────────────────────────────────
TIMEZONE=Asia/Qatar
NODE_ENV=production
LOG_LEVEL=info
POLL_INTERVAL_SECONDS=60
REMINDER_HOURS=2

# ─────────────────────────────────────────
# Client messaging channel
# Values: telegram_draft (current) | whatsapp_cloud (future)
# ─────────────────────────────────────────
CLIENT_CHANNEL=telegram_draft

# WhatsApp Cloud API (не используется пока CLIENT_CHANNEL=telegram_draft)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0
